# ============================================================
#  GLOBAL BOOKSHELF — ENVIRONMENT CONFIGURATION
#  Copy this to .env and fill in your real values
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── SECURITY ─────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=globalbookshelf2025secret

# ── DATABASE ─────────────────────────────────────────────────
# PostgreSQL 15 connection string
DATABASE_URL=postgresql://postgres:54321@localhost:5432/globalbookshelf

# pgvector is installed as an extension — no separate URL needed
# Run this after connecting: CREATE EXTENSION IF NOT EXISTS vector;

# ── STRIPE — VISA CARD PAYMENTS ──────────────────────────────
# Get your keys from: https://dashboard.stripe.com/apikeys
# Test keys start with sk_test_ (no real money)
# Live keys start with sk_live_ (real Visa card charges)

# For TESTING (no real money charged):
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_TEST_PUBLISHABLE_KEY_HERE

# For PRODUCTION (real Visa card charges):
# STRIPE_SECRET_KEY=sk_live_YOUR_LIVE_KEY_HERE
# STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_LIVE_PUBLISHABLE_KEY_HERE

# Webhook secret (get from Stripe Dashboard → Webhooks):
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# What card types are accepted:
# visa, mastercard, amex, discover, jcb, diners, unionpay
# All are enabled by default when payment_method_types: ['card']

# ── AI ENGINE (Python Soul Service) ──────────────────────────
# OpenAI API for generating 1536-dimension soul embeddings
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE

# Soul engine runs as a separate Python service on port 5000
SOUL_ENGINE_URL=http://localhost:5000

# ── REDIS (caching & real-time) ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ── EMAIL (transactional: registration, receipts) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=michaeltostao@gmail.com
SMTP_PASS=btekjoqvfzmvvjyo
SMTP_FROM=Global BookShelf <michaeltostao@gmail.com>

# ── AWS (file storage for cover images, audio) ───────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=af-south-1
AWS_S3_BUCKET=globalbookshelf-assets

# ── CORS ─────────────────────────────────────────────────────
# Add all domains that are allowed to call this API
# FRONTEND_URL=https://globalbookshelf.com
GOOGLE_CLIENT_ID=972446330486-b8a3pojgkpdmdq149g64nk4t762r8d78.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
FRONTEND_URL=http://127.0.0.1:5500

