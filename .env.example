# ── GLOBAL BOOKSHELF — ENVIRONMENT VARIABLES ──
# Copy this file to .env and fill in your values

# ── SERVER ──
NODE_ENV=development
PORT=4000

# ── DATABASE ──
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/globalbookshelf

# ── AUTH ──
JWT_SECRET=globalbookshelf2025secret

# ── STRIPE (payments) ──
# Get from: https://dashboard.stripe.com/apikeys
# For local dev: use sk_test_placeholder (no real charges)
# For production: use your real sk_live_ key
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ── GOOGLE OAUTH (sign in with Google) ──
# Get from: https://console.developers.google.com/
# 1. Create project → Enable Google+ API
# 2. Create OAuth 2.0 credentials
# 3. Add http://localhost:4000/api/auth/google/callback as redirect URI
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ── EMAIL / SMTP ──
# Option A — Gmail (easiest for local dev):
# 1. Enable 2FA on your Gmail account
# 2. Go to myaccount.google.com → Security → App passwords
# 3. Generate a password for "Mail"
# 4. Use your Gmail address as SMTP_USER and the app password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM=Global BookShelf <noreply@globalbookshelf.com>

# Option B — SendGrid (free 100 emails/day):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key

# ── FRONTEND URL (CORS) ──
FRONTEND_URL=http://127.0.0.1:5500

# ── SOUL ENGINE (Python AI) ──
SOUL_ENGINE_URL=http://localhost:5000

# ── CLOUDINARY (image uploads — optional) ──
# Free account at: https://cloudinary.com/
# Uncomment these to use Cloudinary instead of local file storage
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
